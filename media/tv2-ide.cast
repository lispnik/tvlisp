[0.113, "o", "\ufffd\ufffd\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[30;1H\u001b[0;38;5;16;48;5;37m \u2261 Windows \u2502 Tile \u2502 Cascade \u2502 Help \u2502 Exit \u2502                                                         "]
[2.621, "o", "\u001b[?25l\u001b[1;2H\u001b[0;38;5;16;48;5;248m \u001b[0;38;5;124;48;5;248m\u2261\u001b[0;38;5;16;48;5;248m \u001b[1;17H\u001b[0;38;5;231;48;5;34m Lisp \u001b[2;2H\u001b[0;38;5;239;48;5;19m\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[2;17H\u001b[0;38;5;16;48;5;248m\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\u001b[3;2H\u001b[0;38;5;239;48;5;19m\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[3;17H\u001b[0;38;5;16;48;5;248m\u2502\u001b[0;38;5;231;48;5;34m Eval / compile defun \u001b[0;38;5;16;48;5;248m\u2502\u001b[0;38;5;239;48;5;16m\u2592\u2592\u001b[4;2H\u001b[0;38;5;239;48;5;19m\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[4;17H\u001b[0;38;5;16;48;5;248m\u2502 Load buffer          \u2502\u001b[0;38;5;239;48;5;16m\u2592\u2592\u001b[5;4H\u001b[0;38;5;239;48;5;19m\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[5;17H\u001b[0;38;5;16;48;5;248m\u2502 Compile buffer       \u2502\u001b[0;38;5;239;48;5;16m\u2592\u2592\u001b[6;17H\u001b[0;38;5;16;48;5;248m\u2502 Interrupt eval       \u2502\u001b[0;38;5;239;48;5;16m\u2592\u2592\u001b[7;17H\u001b[0;38;5;16;48;5;248m\u251c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524\u001b[0;38;5;239;48;5;16m\u2592\u2592\u001b[8;17H\u001b[0;38;5;16;48;5;248m\u2502 Inspect\u2026  "]
