[0.139, "o", "\u001b[?25l\u001b[1;1H\u001b[0;38;2;0;0;0;48;2;170;170;170m \u001b[0;38;2;255;255;255;48;2;0;170;0m \u2261 \u001b[0;38;2;0;0;0;48;2;170;170;170m \u001b[0;38;2;170;0;0;48;2;170;170;170mF\u001b[0;38;2;0;0;0;48;2;170;170;170mile  \u001b[0;38;2;170;0;0;48;2;170;170;170mE\u001b[0;38;2;0;0;0;48;2;170;170;170mdit  \u001b[0;38;2;170;0;0;48;2;170;170;170mS\u001b[0;38;2;0;0;0;48;2;170;170;170mearch  \u001b[0;38;2;170;0;0;48;2;170;170;170mR\u001b[0;38;2;0;0;0;48;2;170;170;170mun  \u001b[0;38;2;170;0;0;48;2;170;170;170mD\u001b[0;38;2;0;0;0;48;2;170;170;170mebug  \u001b[0;38;2;170;0;0;48;2;170;170;170mB\u001b[0;38;2;0;0;0;48;2;170;170;170mrowse  \u001b[0;38;2;170;0;0;48;2;170;170;170mW\u001b[0;38;2;0;0;0;48;2;170;170;170mindow  \u001b[0;38;2;170;0;0;48;2;170;170;170mO\u001b[0;38;2;0;0;0;48;2;170;170;170mptions  \u001b[0;38;2;170;0;0;48;2;170;170;170mH\u001b[0;38;2;0;0;0;48;2;170;170;170melp                                  \u001b[2;1H\u001b[0;38;2;85;85;85;48;2;0;0;170m\u2592\u001b[0;38;2;255;255;255;48;2;0;170;0m About\u2026     \u001b[0;38;2;85;85;85;48;2;0;0;170m\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592"]
[0.14, "o", "\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[3;1H\u2592\u2592\u2592\u001b[0;38;2;85;85;85;48;2;0;0;0m\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[0;38;2;85;85;85;48;2;0;0;170m\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[4;1H\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u001b[5;1H\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592\u2592